# ==============================================
# AUDITOR FAMILIAR - Environment Variables
# ==============================================
# Copiar este archivo a .env y configurar con valores reales
# NUNCA subir .env a GitHub

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
# Tipo de base de datos: sqlite | postgresql
DB_TYPE=postgresql

# PostgreSQL Configuration (Producción)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# ⚠️ Si tienes otros contenedores PostgreSQL, cambia el puerto (ej: 5433, 5434, etc.)
POSTGRES_DB=auditor_familiar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# SQLite Configuration (DESHABILITADO - el proyecto usa PostgreSQL exclusivamente)
# SQLITE_DB_PATH=shopping.db

# ---------------------------------------------
# Application Configuration
# ---------------------------------------------
# Entorno: development | production | testing
# ⚠️  EN EL SERVIDOR (Orange Pi / VPS): usar APP_ENV=production
#     - Bloquea el comando 'fleting db seed' para evitar cargar datos de prueba en producción
#     - Desactiva debug y mensajes de error detallados
# ✅  EN DESARROLLO LOCAL: usar APP_ENV=development
#     - Permite correr 'fleting db seed' con datos de ejemplo
APP_ENV=production

# Secret key para sesiones — GENERAR UNA NUEVA con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  NUNCA uses el valor de ejemplo en producción
SECRET_KEY=CAMBIA_ESTO_genera_con_python_secrets_token_hex_32

# ---------------------------------------------
# Security
# ---------------------------------------------
# Habilitar modo debug (solo desarrollo — poner False en producción)
DEBUG=False

# Allowed hosts (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------
# Logging
# ---------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ---------------------------------------------
# Docker Configuration
# ---------------------------------------------
# Puerto de la aplicación
APP_PORT=8550
# ⚠️ Si el puerto 8550 está ocupado, cambia a otro (ej: 8551, 8552, etc.)

# pgAdmin (opcional, para administración de BD)
PGADMIN_EMAIL=admin@auditor.local
PGADMIN_PASSWORD=change_this_pgadmin_password
PGADMIN_PORT=5050
# ⚠️ Si el puerto 5050 está ocupado, cambia a otro (ej: 5051, 5052, etc.)

# ---------------------------------------------
# IA y Memoria Vectorial (pgvector + Ollama)
# ---------------------------------------------
# URL de Ollama:
#   - Dentro de Docker:  http://host.docker.internal:11434
#   - Desarrollo local:  http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Modelo de embeddings (768 dimensiones, ~100MB)
# Descargar con: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Activar/desactivar memoria vectorial (true | false)
MEMORY_SERVICE_ENABLED=true

# ---------------------------------------------
# OCR Microservice (ocr_api)
# ---------------------------------------------
# URL INTERNA Docker: como el contenedor 'app' llega al contenedor 'ocr_api'
# No cambiar salvo que renombres el servicio en docker-compose.yml
OCR_API_URL=http://ocr_api:8551

# URL PUBLICA: como el BROWSER del usuario llega al formulario OCR
# ⚠️  Esta es la variable crítica para producción con Cloudflare Tunnel:
#
#   LOCAL:              OCR_API_PUBLIC_URL=http://localhost:8551
#   CLOUDFLARE TUNNEL:  OCR_API_PUBLIC_URL=https://ocr.tu-dominio.com
#
# Si no configurás esta variable correctamente, el link del formulario
# OCR no funcionará para los usuarios (apuntará a localhost del servidor)
OCR_API_PUBLIC_URL=http://localhost:8551

# ---------------------------------------------
# Seguridad — Rate Limiting y Sesiones
# ---------------------------------------------
# Máximo intentos fallidos de login antes de bloqueo temporal
AUTH_MAX_INTENTOS=5

# Ventana de tiempo en segundos para contar fallos (default: 900 = 15 min)
AUTH_VENTANA_SEGUNDOS=900

# Tiempo de bloqueo tras superar el límite (default: 900 = 15 min)
AUTH_BLOQUEO_SEGUNDOS=900

# Timeout de sesión inactiva en segundos (default: 28800 = 8 horas)
# Reducir a 3600 (1 hora) si querés más seguridad
SESSION_TIMEOUT_SEGUNDOS=28800
